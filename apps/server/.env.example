# Copy the values you need into your local shell environment before starting the backend.
# PowerShell example:
#   $env:BOWER_AI_PROVIDER="openai"
#   $env:BOWER_OPENAI_API_KEY="your-key"
# Bash / zsh example:
#   export BOWER_AI_PROVIDER="openai"
#   export BOWER_OPENAI_API_KEY="your-key"

BOWER_AI_PROVIDER=openai
BOWER_OPENAI_API_KEY=your-openai-api-key
BOWER_OPENAI_MODEL=gpt-4.1-mini
# Optional override for OpenAI-compatible providers.
# Leave unset for the official OpenAI API.
# BOWER_OPENAI_BASE_URL=https://api.openai.com

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
