{
  "name": "bower",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "uv run --directory apps/server uvicorn app.main:app --reload",
    "sync:server": "uv sync --directory apps/server",
    "test:server": "uv run --directory apps/server pytest",
    "install:web": "npm install --prefix apps/web",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.5.4"
  }
}
