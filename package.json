{
  "name": "bower",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev:server": "python -m uvicorn app.main:app --reload --app-dir apps/server",
    "install:web": "npm install --prefix apps/web",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
